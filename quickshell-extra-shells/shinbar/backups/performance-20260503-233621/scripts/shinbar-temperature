#!/usr/bin/env python3
import json
import os
import urllib.parse
import urllib.request
from datetime import datetime

def configured_location():
    env_location = os.environ.get("SHINBAR_WEATHER_LOCATION", "").strip()
    if env_location and env_location.lower() != "auto":
        return env_location

    path = os.path.expanduser("~/.config/quickshell/shinbar/savedata.json")
    try:
        with open(path, "r", encoding="utf-8") as f:
            value = json.load(f).get("weatherCity", "")
        value = str(value).strip()
        if value and value.lower() != "auto":
            return value
    except Exception:
        pass

    return "Guarulhos"

LOCATION = configured_location()
if not LOCATION or LOCATION.lower() == "auto":
    LOCATION = "Guarulhos"
WEEK_PT = ["Seg", "Ter", "Qua", "Qui", "Sex", "Sáb", "Dom"]

CODES = {
    0: "Céu limpo",
    1: "Principalmente limpo",
    2: "Parcialmente nublado",
    3: "Nublado",
    45: "Neblina",
    48: "Neblina densa",
    51: "Garoa leve",
    53: "Garoa moderada",
    55: "Garoa intensa",
    61: "Chuva leve",
    63: "Chuva moderada",
    65: "Chuva forte",
    80: "Pancadas leves",
    81: "Pancadas moderadas",
    82: "Pancadas fortes",
    95: "Trovoadas",
    96: "Trovoadas com granizo",
    99: "Trovoadas fortes",
}

def get_json(url):
    req = urllib.request.Request(url, headers={"User-Agent": "shinbar-weather/1.0"})
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read().decode("utf-8"))

try:
    q = urllib.parse.quote(LOCATION)
    geo = get_json(f"https://geocoding-api.open-meteo.com/v1/search?name={q}&count=1&language=pt&format=json")
    results = geo.get("results") or []
    if not results:
        raise RuntimeError("localização não encontrada")

    place = results[0]
    lat = place["latitude"]
    lon = place["longitude"]

    city = place.get("name", LOCATION)
    admin = place.get("admin1", "")
    country = place.get("country", "")

    location = city
    if admin:
        location += ", " + admin
    if country:
        location += ", " + country

    url = (
        "https://api.open-meteo.com/v1/forecast?"
        f"latitude={lat}&longitude={lon}"
        "&current=temperature_2m,relative_humidity_2m,apparent_temperature,precipitation,weather_code,cloud_cover,wind_speed_10m,wind_direction_10m"
        "&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,wind_speed_10m_max"
        "&forecast_days=7"
        "&timezone=auto"
    )

    data = get_json(url)
    cur = data.get("current", {})
    daily = data.get("daily", {})

    code = int(cur.get("weather_code", 0))
    desc = CODES.get(code, "Clima atual")

    days = []
    times = daily.get("time", [])
    maxs = daily.get("temperature_2m_max", [])
    mins = daily.get("temperature_2m_min", [])
    rains = daily.get("precipitation_probability_max", [])
    winds = daily.get("wind_speed_10m_max", [])
    codes = daily.get("weather_code", [])

    for i in range(min(7, len(times))):
        raw = times[i]
        try:
            dt = datetime.strptime(raw, "%Y-%m-%d")
            label = WEEK_PT[dt.weekday()]
            short = dt.strftime("%d/%m")
        except Exception:
            label = raw
            short = raw

        dcode = int(codes[i]) if i < len(codes) and codes[i] is not None else 0

        days.append({
            "date": raw,
            "label": label,
            "short": short,
            "min": round(mins[i]) if i < len(mins) and mins[i] is not None else "--",
            "max": round(maxs[i]) if i < len(maxs) and maxs[i] is not None else "--",
            "rain": round(rains[i]) if i < len(rains) and rains[i] is not None else 0,
            "wind": round(winds[i]) if i < len(winds) and winds[i] is not None else "--",
            "desc": CODES.get(dcode, "Clima"),
        })

    print(f"LOCATION={location}")
    print(f"TEMP={round(cur.get('temperature_2m')) if cur.get('temperature_2m') is not None else '--'}")
    print(f"FEELS={round(cur.get('apparent_temperature')) if cur.get('apparent_temperature') is not None else '--'}")
    print(f"DESC={desc}")
    print(f"HUMIDITY={round(cur.get('relative_humidity_2m')) if cur.get('relative_humidity_2m') is not None else '--'}")
    print(f"WIND={round(cur.get('wind_speed_10m')) if cur.get('wind_speed_10m') is not None else '--'}")
    print(f"WIND_DIR={round(cur.get('wind_direction_10m')) if cur.get('wind_direction_10m') is not None else '--'}°")
    print(f"PRECIP={cur.get('precipitation', 0)}")
    print(f"CLOUDCOVER={round(cur.get('cloud_cover')) if cur.get('cloud_cover') is not None else '--'}")
    print("DAYS=" + json.dumps(days, ensure_ascii=False))

except Exception as e:
    print("LOCATION=Offline")
    print("TEMP=--")
    print("FEELS=--")
    print("DESC=Sem dados")
    print("HUMIDITY=--")
    print("WIND=--")
    print("WIND_DIR=")
    print("PRECIP=0")
    print("CLOUDCOVER=--")
    print("DAYS=[]")
