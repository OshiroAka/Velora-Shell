#!/usr/bin/env bash
set -euo pipefail

mode="${1:-full}"

if ! command -v grim >/dev/null 2>&1; then
  notify-send "Velora screenshot" "grim nao esta instalado." >/dev/null 2>&1 || true
  exit 1
fi

out_dir="$HOME/Pictures/Screenshots"
mkdir -p "$out_dir"
out_file="$out_dir/velora-${mode}-$(date +'%Y-%m-%d_%H-%M-%S').png"

case "$mode" in
  full|screen)
    grim "$out_file"
    ;;
  select|area|region)
    if ! command -v slurp >/dev/null 2>&1; then
      notify-send "Velora screenshot" "slurp nao esta instalado. Instale: sudo pacman -S slurp" >/dev/null 2>&1 || true
      exit 1
    fi
    geometry="$(slurp)" || exit 0
    [ -n "$geometry" ] || exit 0
    grim -g "$geometry" "$out_file"
    ;;
  *)
    notify-send "Velora screenshot" "Modo invalido: $mode" >/dev/null 2>&1 || true
    printf 'usage: %s [full|select]\n' "$0" >&2
    exit 2
    ;;
esac

if command -v wl-copy >/dev/null 2>&1; then
  wl-copy --type image/png < "$out_file" || wl-copy < "$out_file" || true
fi

notify-send "Velora screenshot" "Salvo e copiado: $out_file" >/dev/null 2>&1 || true
