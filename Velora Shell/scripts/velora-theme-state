#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/velora-shell"
state_file="${state_dir}/theme"
opacity_file="${state_dir}/opacity"
bar_opacity_file="${state_dir}/bar-opacity"
glow_file="${state_dir}/glow"
border_file="${state_dir}/border"
layout_file="${state_dir}/layout"
language_file="${state_dir}/language"
font_file="${state_dir}/font"
visualizer_file="${state_dir}/visualizer"
visualizer_mode_file="${state_dir}/visualizer-mode"
visualizer_pixel_size_file="${state_dir}/visualizer-pixel-size"
visualizer_gradient_file="${state_dir}/visualizer-gradient"
screen_visualizer_file="${state_dir}/screen-visualizer"
topbar_file="${state_dir}/topbar"
topbar_frame_line_file="${state_dir}/topbar-frame-line"
popup_attach_file="${state_dir}/popup-attach"
popup_bubbles_file="${state_dir}/popup-bubbles"
wallpaper_transition_file="${state_dir}/wallpaper-transition"
lyrics_file="${state_dir}/lyrics"
lyrics_cinematic_file="${state_dir}/lyrics-cinematic"
lyrics_mask_file="${state_dir}/lyrics-mask"
lyrics_blocks_file="${state_dir}/lyrics-blocks"
lyrics_transform_file="${state_dir}/lyrics-transform"
lyrics_material_file="${state_dir}/lyrics-material"
bar_labels_file="${state_dir}/bar-labels"
bar_blur_file="${state_dir}/bar-blur"
frame_blur_file="${state_dir}/frame-blur"
bar_appearance_file="${state_dir}/bar-appearance"
profile_image_file="${state_dir}/profile-image"
command="${1:-get}"

normalize_on_off() {
  case "${1:-on}" in
    1|true|yes|on|enable|enabled)
      printf 'on\n'
      ;;
    *)
      printf 'off\n'
      ;;
  esac
}

normalize_visualizer_mode() {
  case "${1:-wave}" in
    pixels|pixel|grid|squares|square)
      printf 'pixels\n'
      ;;
    *)
      printf 'wave\n'
      ;;
  esac
}

normalize_font() {
  case "${1:-noto}" in
    noto|noto-sans|noto_sans)
      printf 'noto\n'
      ;;
    adwaita|adwaita-sans|adwaita_sans)
      printf 'adwaita\n'
      ;;
    cantarell)
      printf 'cantarell\n'
      ;;
    dejavu|dejavu-sans|dejavu_sans)
      printf 'dejavu\n'
      ;;
    liberation|liberation-sans|liberation_sans)
      printf 'liberation\n'
      ;;
    fantasque|fantasque-sans|fantasquesansm)
      printf 'fantasque\n'
      ;;
    *)
      printf 'noto\n'
      ;;
  esac
}

normalize_popup_bubbles() {
  case "${1:-matched}" in
    1|true|yes|on|solid|solids)
      printf 'solid\n'
      ;;
    *)
      printf 'matched\n'
      ;;
  esac
}

normalize_wallpaper_transition() {
  case "${1:-fade}" in
    none|simple|fade|left|right|top|bottom|wipe|wave|grow|center|any|outer|random)
      printf '%s\n' "$1"
      ;;
    *)
      printf 'fade\n'
      ;;
  esac
}

normalize_lyrics_color_mode() {
  case "${1:-pywal}" in
    palette|wallpaper|dynamic|colors)
      printf 'palette\n'
      ;;
    manual|custom|color)
      printf 'manual\n'
      ;;
    *)
      printf 'pywal\n'
      ;;
  esac
}

normalize_lyrics_layout() {
  case "${1:-vertical}" in
    simple|single|plain)
      printf 'simple\n'
      ;;
    cascade|stack|centered)
      printf '%s\n' "$1"
      ;;
    two|twolyrics|two-lyrics|split|double|duo)
      printf 'two\n'
      ;;
    four|fourlyrics|four-lyrics|quad)
      printf 'four\n'
      ;;
    *)
      printf 'vertical\n'
      ;;
  esac
}

normalize_lyrics_animation() {
  case "${1:-instant}" in
    fade|slide)
      printf '%s\n' "$1"
      ;;
    *)
      printf 'instant\n'
      ;;
  esac
}

normalize_lyrics_reveal() {
  case "${1:-progressive}" in
    line|full|complete|all)
      printf 'line\n'
      ;;
    current|word|active)
      printf 'current\n'
      ;;
    *)
      printf 'progressive\n'
      ;;
  esac
}

normalize_lyrics_material_mode() {
  case "${1:-off}" in
    off|none|disable|disabled)
      printf 'off\n'
      ;;
    cloud|fog|mist|soft)
      printf 'cloud\n'
      ;;
    glass|frost|frosted)
      printf 'glass\n'
      ;;
    metal|silver|chrome)
      printf 'metal\n'
      ;;
    sky|ambient|atmosphere)
      printf 'sky\n'
      ;;
    *)
      printf 'off\n'
      ;;
  esac
}

normalize_hex_color() {
  local value="${1:-#f5f7ff}"
  value="${value//$'\n'/}"
  value="${value//$'\r'/}"
  value="${value//$'\t'/}"
  value="${value// /}"
  [[ "$value" != \#* ]] && value="#$value"
  if [[ "$value" =~ ^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$ ]]; then
    printf '%s\n' "$value"
  else
    printf '#f5f7ff\n'
  fi
}

sanitize_json_array() {
  local value="${1:-[]}"
  value="${value//$'\n'/}"
  value="${value//$'\r'/}"
  value="${value//$'\t'/}"
  if ((${#value} > 180000)); then
    printf '[]\n'
    return
  fi
  if [[ "$value" == \[*\] ]]; then
    printf '%s\n' "$value"
  else
    printf '[]\n'
  fi
}

clamp_decimal() {
  local value="${1:-}"
  local fallback="${2:-0}"
  local min="${3:-0}"
  local max="${4:-1}"

  awk -v value="$value" -v fallback="$fallback" -v min="$min" -v max="$max" '
    BEGIN {
      if (value !~ /^-?[0-9]+([.][0-9]+)?$/)
        value = fallback
      value += 0
      if (value < min)
        value = min
      if (value > max)
        value = max
      printf "%.2f\n", value
    }
  '
}

read_lyrics_mask_settings() {
  local config="off|56.00|[]"
  local enabled
  local brush_size
  local mask_data

  [[ -s "$lyrics_mask_file" ]] && config="$(cat "$lyrics_mask_file")"
  IFS='|' read -r enabled brush_size mask_data <<< "$config"
  enabled="$(normalize_on_off "${enabled:-off}")"
  brush_size="$(clamp_decimal "${brush_size:-56}" "56" "6" "180")"
  mask_data="$(sanitize_json_array "${mask_data:-[]}")"
  printf '%s|%s|%s\n' "$enabled" "$brush_size" "$mask_data"
}

read_lyrics_blocks_settings() {
  local config="8.00|58.00|72.00|58.00|[]"
  local -a parts
  local pos3_x
  local pos3_y
  local pos4_x
  local pos4_y
  local styles

  [[ -s "$lyrics_blocks_file" ]] && config="$(cat "$lyrics_blocks_file")"
  IFS='|' read -r -a parts <<< "$config"
  pos3_x="$(clamp_decimal "${parts[0]:-8}" "8" "0" "100")"
  pos3_y="$(clamp_decimal "${parts[1]:-58}" "58" "0" "100")"
  pos4_x="$(clamp_decimal "${parts[2]:-72}" "72" "0" "100")"
  pos4_y="$(clamp_decimal "${parts[3]:-58}" "58" "0" "100")"
  styles="$(sanitize_json_array "${parts[*]:4}")"
  printf '%s|%s|%s|%s|%s\n' "$pos3_x" "$pos3_y" "$pos4_x" "$pos4_y" "$styles"
}

read_lyrics_transform_settings() {
  local config="1.00|0.00|0.00|0.00"
  local scale
  local rotation
  local tilt_x
  local tilt_y

  [[ -s "$lyrics_transform_file" ]] && config="$(cat "$lyrics_transform_file")"
  IFS='|' read -r scale rotation tilt_x tilt_y <<< "$config"
  scale="$(clamp_decimal "${scale:-1}" "1" "0.35" "2.50")"
  rotation="$(clamp_decimal "${rotation:-0}" "0" "-60" "60")"
  tilt_x="$(clamp_decimal "${tilt_x:-0}" "0" "-70" "70")"
  tilt_y="$(clamp_decimal "${tilt_y:-0}" "0" "-70" "70")"
  printf '%s|%s|%s|%s\n' "$scale" "$rotation" "$tilt_x" "$tilt_y"
}

read_lyrics_material_settings() {
  local config="off|0.55|off|0.45|off|0.35|0.00"
  local mode
  local intensity
  local depth_enabled
  local depth_intensity
  local fog_enabled
  local fog_intensity
  local mask_feather

  [[ -s "$lyrics_material_file" ]] && config="$(cat "$lyrics_material_file")"
  IFS='|' read -r mode intensity depth_enabled depth_intensity fog_enabled fog_intensity mask_feather <<< "$config"
  mode="$(normalize_lyrics_material_mode "${mode:-off}")"
  intensity="$(clamp_decimal "${intensity:-0.55}" "0.55" "0" "1.00")"
  depth_enabled="$(normalize_on_off "${depth_enabled:-off}")"
  depth_intensity="$(clamp_decimal "${depth_intensity:-0.45}" "0.45" "0" "1.00")"
  fog_enabled="$(normalize_on_off "${fog_enabled:-off}")"
  fog_intensity="$(clamp_decimal "${fog_intensity:-0.35}" "0.35" "0" "1.00")"
  mask_feather="$(clamp_decimal "${mask_feather:-0}" "0" "0" "80")"
  printf '%s|%s|%s|%s|%s|%s|%s\n' "$mode" "$intensity" "$depth_enabled" "$depth_intensity" "$fog_enabled" "$fog_intensity" "$mask_feather"
}

read_wallpaper_transition() {
  local config="fade|1.00|0.12"
  local transition
  local duration
  local delay

  [[ -s "$wallpaper_transition_file" ]] && config="$(cat "$wallpaper_transition_file")"
  IFS='|' read -r transition duration delay <<< "$config"
  transition="$(normalize_wallpaper_transition "${transition:-fade}")"
  duration="$(clamp_decimal "${duration:-1.00}" "1.00" "0.15" "3.00")"
  delay="$(clamp_decimal "${delay:-0.12}" "0.12" "0" "0.80")"
  printf '%s|%s|%s\n' "$transition" "$duration" "$delay"
}

read_bar_appearance() {
  local config="48.00|0.80|16.00|off|16.00"
  local icon_size
  local icon_opacity
  local icon_spacing
  local auto_hide
  local corner_radius

  [[ -s "$bar_appearance_file" ]] && config="$(cat "$bar_appearance_file")"
  IFS='|' read -r icon_size icon_opacity icon_spacing auto_hide corner_radius <<< "$config"
  icon_size="$(clamp_decimal "${icon_size:-48}" "48" "32" "56")"
  icon_opacity="$(clamp_decimal "${icon_opacity:-0.80}" "0.80" "0.30" "1.00")"
  icon_spacing="$(clamp_decimal "${icon_spacing:-16}" "16" "8" "24")"
  auto_hide="$(normalize_on_off "${auto_hide:-off}")"
  corner_radius="$(clamp_decimal "${corner_radius:-16}" "16" "0" "30")"
  printf '%s|%s|%s|%s|%s\n' "$icon_size" "$icon_opacity" "$icon_spacing" "$auto_hide" "$corner_radius"
}

read_lyrics_settings() {
  local config="off|18.00|44.00|pywal|#f5f7ff|86.00|0.86|8.00|on|on|vertical|instant|on|progressive|74.00|18.00|460.00|on|5.00|glow|on|0.45"
  local -a parts
  local enabled
  local pos_x
  local pos_y
  local color_mode
  local manual_color
  local font_size
  local opacity
  local spacing
  local shadow
  local uppercase
  local layout
  local animation
  local active_word
  local reveal_mode
  local pos2_x
  local pos2_y
  local sync_offset
  local float_enabled
  local float_intensity
  local glow_enabled
  local glow_intensity

  [[ -s "$lyrics_file" ]] && config="$(cat "$lyrics_file")"
  IFS='|' read -r -a parts <<< "$config"
  enabled="${parts[0]:-off}"
  pos_x="${parts[1]:-18}"
  pos_y="${parts[2]:-44}"
  color_mode="${parts[3]:-pywal}"
  manual_color="${parts[4]:-#f5f7ff}"
  font_size="${parts[5]:-86}"
  opacity="${parts[6]:-0.86}"
  spacing="${parts[7]:-8}"
  shadow="${parts[8]:-on}"
  uppercase="${parts[9]:-on}"
  layout="${parts[10]:-vertical}"
  animation="${parts[11]:-instant}"
  active_word="${parts[12]:-on}"
  reveal_mode="${parts[13]:-progressive}"
  pos2_x="${parts[14]:-74}"
  pos2_y="${parts[15]:-18}"
  sync_offset="${parts[16]:-460}"
  float_enabled="${parts[17]:-on}"
  float_intensity="${parts[18]:-5}"
  if [[ "${parts[19]:-}" == "glow" ]]; then
    glow_enabled="${parts[20]:-on}"
    glow_intensity="${parts[21]:-0.45}"
  else
    glow_enabled="on"
    glow_intensity="0.45"
  fi
  enabled="$(normalize_on_off "${enabled:-off}")"
  pos_x="$(clamp_decimal "${pos_x:-18}" "18" "0" "100")"
  pos_y="$(clamp_decimal "${pos_y:-44}" "44" "0" "100")"
  color_mode="$(normalize_lyrics_color_mode "${color_mode:-pywal}")"
  manual_color="$(normalize_hex_color "${manual_color:-#f5f7ff}")"
  font_size="$(clamp_decimal "${font_size:-86}" "86" "24" "180")"
  opacity="$(clamp_decimal "${opacity:-0.86}" "0.86" "0.15" "1.00")"
  spacing="$(clamp_decimal "${spacing:-8}" "8" "0" "48")"
  shadow="$(normalize_on_off "${shadow:-on}")"
  uppercase="$(normalize_on_off "${uppercase:-on}")"
  layout="$(normalize_lyrics_layout "${layout:-vertical}")"
  animation="$(normalize_lyrics_animation "${animation:-instant}")"
  active_word="$(normalize_on_off "${active_word:-on}")"
  reveal_mode="$(normalize_lyrics_reveal "${reveal_mode:-progressive}")"
  pos2_x="$(clamp_decimal "${pos2_x:-74}" "74" "0" "100")"
  pos2_y="$(clamp_decimal "${pos2_y:-18}" "18" "0" "100")"
  sync_offset="$(clamp_decimal "${sync_offset:-460}" "460" "-3000" "3000")"
  float_enabled="$(normalize_on_off "${float_enabled:-on}")"
  float_intensity="$(clamp_decimal "${float_intensity:-5}" "5" "0" "24")"
  glow_enabled="$(normalize_on_off "${glow_enabled:-on}")"
  glow_intensity="$(clamp_decimal "${glow_intensity:-0.45}" "0.45" "0" "1.00")"
  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|glow|%s|%s\n' "$enabled" "$pos_x" "$pos_y" "$color_mode" "$manual_color" "$font_size" "$opacity" "$spacing" "$shadow" "$uppercase" "$layout" "$animation" "$active_word" "$reveal_mode" "$pos2_x" "$pos2_y" "$sync_offset" "$float_enabled" "$float_intensity" "$glow_enabled" "$glow_intensity"
}

case "$command" in
  get)
    if [[ -s "$state_file" ]]; then
      cat "$state_file"
    else
      printf 'default\n'
    fi
    ;;
  dump)
    theme="default"
    opacity="auto"
    bar_opacity="auto"
    glow="auto"
    border="auto"
    layout="left|1"
    language="pt-BR"
    font="noto"
    visualizer="0.46"
    visualizer_mode="wave"
    visualizer_pixel_size="7.00"
    visualizer_gradient="on"
    screen_visualizer="off"
    topbar="off"
    topbar_frame_line="on"
    popup_attach="on"
    popup_bubbles="matched"
    bar_labels="on"
    bar_blur="on"
    frame_blur="on"
    bar_appearance="$(read_bar_appearance)"
    profile_image=""
    wallpaper_transition="$(read_wallpaper_transition)"
    lyrics="$(read_lyrics_settings)"
    lyrics_cinematic="on"
    lyrics_mask="$(read_lyrics_mask_settings)"
    lyrics_blocks="$(read_lyrics_blocks_settings)"
    lyrics_transform="$(read_lyrics_transform_settings)"
    lyrics_material="$(read_lyrics_material_settings)"

    [[ -s "$state_file" ]] && theme="$(cat "$state_file")"
    [[ -s "$opacity_file" ]] && opacity="$(cat "$opacity_file")"
    [[ -s "$bar_opacity_file" ]] && bar_opacity="$(cat "$bar_opacity_file")"
    [[ -s "$glow_file" ]] && glow="$(cat "$glow_file")"
    [[ -s "$border_file" ]] && border="$(cat "$border_file")"
    [[ -s "$layout_file" ]] && layout="$(cat "$layout_file")"
    [[ -s "$language_file" ]] && language="$(cat "$language_file")"
    [[ -s "$font_file" ]] && font="$(normalize_font "$(cat "$font_file")")"
    [[ -s "$visualizer_file" ]] && visualizer="$(cat "$visualizer_file")"
    [[ -s "$visualizer_mode_file" ]] && visualizer_mode="$(normalize_visualizer_mode "$(cat "$visualizer_mode_file")")"
    [[ -s "$visualizer_pixel_size_file" ]] && visualizer_pixel_size="$(clamp_decimal "$(cat "$visualizer_pixel_size_file")" "7.00" "3" "12")"
    [[ -s "$visualizer_gradient_file" ]] && visualizer_gradient="$(normalize_on_off "$(cat "$visualizer_gradient_file")")"
    [[ -s "$screen_visualizer_file" ]] && screen_visualizer="$(normalize_on_off "$(cat "$screen_visualizer_file")")"
    [[ -s "$topbar_file" ]] && topbar="$(cat "$topbar_file")"
    [[ -s "$topbar_frame_line_file" ]] && topbar_frame_line="$(normalize_on_off "$(cat "$topbar_frame_line_file")")"
    [[ -s "$popup_attach_file" ]] && popup_attach="$(normalize_on_off "$(cat "$popup_attach_file")")"
    [[ -s "$popup_bubbles_file" ]] && popup_bubbles="$(normalize_popup_bubbles "$(cat "$popup_bubbles_file")")"
    [[ -s "$bar_labels_file" ]] && bar_labels="$(normalize_on_off "$(cat "$bar_labels_file")")"
    [[ -s "$bar_blur_file" ]] && bar_blur="$(normalize_on_off "$(cat "$bar_blur_file")")"
    [[ -s "$frame_blur_file" ]] && frame_blur="$(normalize_on_off "$(cat "$frame_blur_file")")"
    [[ -s "$profile_image_file" ]] && profile_image="$(cat "$profile_image_file")"
    [[ -s "$lyrics_cinematic_file" ]] && lyrics_cinematic="$(normalize_on_off "$(cat "$lyrics_cinematic_file")")"

    printf 'theme|%s\n' "$theme"
    printf 'opacity|%s\n' "$opacity"
    printf 'barOpacity|%s\n' "$bar_opacity"
    printf 'glow|%s\n' "$glow"
    printf 'border|%s\n' "$border"
    printf 'layout|%s\n' "$layout"
    printf 'language|%s\n' "$language"
    printf 'font|%s\n' "$font"
    printf 'visualizer|%s\n' "$visualizer"
    printf 'visualizerMode|%s\n' "$visualizer_mode"
    printf 'visualizerPixelSize|%s\n' "$visualizer_pixel_size"
    printf 'visualizerGradient|%s\n' "$visualizer_gradient"
    printf 'screenVisualizer|%s\n' "$screen_visualizer"
    printf 'topBar|%s\n' "$topbar"
    printf 'topBarFrameLine|%s\n' "$topbar_frame_line"
    printf 'popupAttach|%s\n' "$popup_attach"
    printf 'popupBubbles|%s\n' "$popup_bubbles"
    printf 'barLabels|%s\n' "$bar_labels"
    printf 'barBlur|%s\n' "$bar_blur"
    printf 'frameBlur|%s\n' "$frame_blur"
    printf 'barAppearance|%s\n' "$bar_appearance"
    printf 'profileImage|%s\n' "$profile_image"
    printf 'wallpaperTransition|%s\n' "$wallpaper_transition"
    printf 'lyrics|%s\n' "$lyrics"
    printf 'lyricsCinematic|%s\n' "$lyrics_cinematic"
    printf 'lyricsMask|%s\n' "$lyrics_mask"
    printf 'lyricsBlocks|%s\n' "$lyrics_blocks"
    printf 'lyricsTransform|%s\n' "$lyrics_transform"
    printf 'lyricsMaterial|%s\n' "$lyrics_material"
    ;;
  set)
    theme="${2:-default}"
    case "$theme" in
      default|dark|pink|lavender|pywal16) ;;
      *) theme="default" ;;
    esac
    mkdir -p "$state_dir"
    printf '%s\n' "$theme" > "$state_file"
    ;;
  opacity)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$opacity_file" ]]; then
          cat "$opacity_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        sidebar="${3:-auto}"
        popup="${4:-auto}"
        card="${5:-auto}"
        mkdir -p "$state_dir"
        printf '%s|%s|%s\n' "$sidebar" "$popup" "$card" > "$opacity_file"
        ;;
      reset)
        rm -f "$opacity_file" "$bar_opacity_file"
        ;;
      *)
        printf 'usage: %s opacity get|set|reset [sidebar popup card]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  bar-opacity)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$bar_opacity_file" ]]; then
          cat "$bar_opacity_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        opacity="${3:-auto}"
        mkdir -p "$state_dir"
        printf '%s\n' "$opacity" > "$bar_opacity_file"
        ;;
      reset)
        rm -f "$bar_opacity_file"
        ;;
      *)
        printf 'usage: %s bar-opacity get|set|reset [opacity]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  glow)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$glow_file" ]]; then
          cat "$glow_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        general="${3:-auto}"
        sidebar_border="${4:-auto}"
        popup_border="${5:-auto}"
        icon="${6:-$general}"
        text="${7:-auto}"
        mkdir -p "$state_dir"
        printf '%s|%s|%s|%s|%s\n' "$general" "$sidebar_border" "$popup_border" "$icon" "$text" > "$glow_file"
        ;;
      reset)
        rm -f "$glow_file"
        ;;
      *)
        printf 'usage: %s glow get|set|reset [general sidebar_border popup_border icon text]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  border)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$border_file" ]]; then
          cat "$border_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        mode="${3:-adapt}"
        hue="${4:-0.55}"
        case "$mode" in
          adapt|manual) ;;
          *) mode="adapt" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s|%s\n' "$mode" "$hue" > "$border_file"
        ;;
      reset)
        rm -f "$border_file"
        ;;
      *)
        printf 'usage: %s border get|set|reset [adapt|manual hue]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  layout)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$layout_file" ]]; then
          cat "$layout_file"
        else
          printf 'left|1\n'
        fi
        ;;
      set)
        position="${3:-left}"
        frame="${4:-1}"
        case "$position" in
          left|right) ;;
          *) position="left" ;;
        esac
        case "$frame" in
          1|true|yes|on) frame="1" ;;
          *) frame="0" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s|%s\n' "$position" "$frame" > "$layout_file"
        ;;
      reset)
        rm -f "$layout_file"
        ;;
      *)
        printf 'usage: %s layout get|set|reset [left|right] [0|1]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  language)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$language_file" ]]; then
          cat "$language_file"
        else
          printf 'pt-BR\n'
        fi
        ;;
      set)
        language="${3:-pt-BR}"
        case "$language" in
          ja|jp|japanese) language="ja" ;;
          en|english) language="en" ;;
          pt|pt-BR|pt_BR|br|portuguese|portugues) language="pt-BR" ;;
          *) language="pt-BR" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s\n' "$language" > "$language_file"
        ;;
      reset)
        rm -f "$language_file"
        ;;
      *)
        printf 'usage: %s language get|set|reset [ja|en|pt-BR]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  font)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$font_file" ]]; then
          normalize_font "$(cat "$font_file")"
        else
          printf 'noto\n'
        fi
        ;;
      set)
        font="$(normalize_font "${3:-noto}")"
        mkdir -p "$state_dir"
        printf '%s\n' "$font" > "$font_file"
        ;;
      reset)
        rm -f "$font_file"
        ;;
      *)
        printf 'usage: %s font get|set|reset [noto|adwaita|cantarell|dejavu|liberation|fantasque]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  visualizer)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$visualizer_file" ]]; then
          cat "$visualizer_file"
        else
          printf '0.46\n'
        fi
        ;;
      set)
        strength="${3:-0.46}"
        mkdir -p "$state_dir"
        printf '%s\n' "$strength" > "$visualizer_file"
        ;;
      reset)
        rm -f "$visualizer_file"
        ;;
      *)
        printf 'usage: %s visualizer get|set|reset [strength]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  visualizer-mode)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$visualizer_mode_file" ]]; then
          normalize_visualizer_mode "$(cat "$visualizer_mode_file")"
        else
          printf 'wave\n'
        fi
        ;;
      set)
        mode="$(normalize_visualizer_mode "${3:-wave}")"
        mkdir -p "$state_dir"
        printf '%s\n' "$mode" > "$visualizer_mode_file"
        ;;
      reset)
        rm -f "$visualizer_mode_file"
        ;;
      *)
        printf 'usage: %s visualizer-mode get|set|reset [wave|pixels]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  visualizer-pixel-size)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$visualizer_pixel_size_file" ]]; then
          clamp_decimal "$(cat "$visualizer_pixel_size_file")" "7.00" "3" "12"
        else
          printf '7.00\n'
        fi
        ;;
      set)
        size="$(clamp_decimal "${3:-7.00}" "7.00" "3" "12")"
        mkdir -p "$state_dir"
        printf '%s\n' "$size" > "$visualizer_pixel_size_file"
        ;;
      reset)
        rm -f "$visualizer_pixel_size_file"
        ;;
      *)
        printf 'usage: %s visualizer-pixel-size get|set|reset [3-12]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  visualizer-gradient)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$visualizer_gradient_file" ]]; then
          normalize_on_off "$(cat "$visualizer_gradient_file")"
        else
          printf 'off\n'
        fi
        ;;
      set)
        enabled="$(normalize_on_off "${3:-on}")"
        mkdir -p "$state_dir"
        printf '%s\n' "$enabled" > "$visualizer_gradient_file"
        ;;
      reset)
        rm -f "$visualizer_gradient_file"
        ;;
      *)
        printf 'usage: %s visualizer-gradient get|set|reset [on|off]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  screen-visualizer)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$screen_visualizer_file" ]]; then
          normalize_on_off "$(cat "$screen_visualizer_file")"
        else
          printf 'on\n'
        fi
        ;;
