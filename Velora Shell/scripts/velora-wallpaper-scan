#!/usr/bin/env bash
set -euo pipefail

cache_root="$HOME/.cache/velora-shell"
cache_live="$cache_root/live-previews"
cache_engine="$cache_root/engine-previews"
runtime_root="${XDG_RUNTIME_DIR:-}"
if [ -z "$runtime_root" ] || [ ! -d "$runtime_root" ]; then
  runtime_root="/dev/shm"
fi
cache_ram="$runtime_root/velora-shell/wallpaper-previews"
declare -A seen_static=()
declare -A seen_engine=()

mkdir -p "$cache_live" "$cache_engine"
if ! mkdir -p "$cache_ram" >/dev/null 2>&1 || ! touch "$cache_ram/.write-test" >/dev/null 2>&1; then
  cache_ram="/tmp/velora-shell/wallpaper-previews"
  if ! mkdir -p "$cache_ram" >/dev/null 2>&1 || ! touch "$cache_ram/.write-test" >/dev/null 2>&1; then
    cache_ram="/dev/shm/velora-shell/wallpaper-previews"
    if ! mkdir -p "$cache_ram" >/dev/null 2>&1 || ! touch "$cache_ram/.write-test" >/dev/null 2>&1; then
      cache_ram="$cache_root/ram-fallback-previews"
      mkdir -p "$cache_ram"
    fi
  fi
fi
rm -f "$cache_ram/.write-test" >/dev/null 2>&1 || true
cache_list="$cache_ram/wallpapers.list"
cache_lock="$cache_ram/wallpapers.lock"
find "$cache_ram" -type f -mmin +720 -delete >/dev/null 2>&1 || true

emit_cached_list() {
  [ -s "$cache_list" ] || return 1
  find "$cache_list" -mmin -10 -print -quit 2>/dev/null | grep -q . || return 1
  cat "$cache_list"
  return 0
}

if [ "${1:-}" != "--refresh" ] && emit_cached_list; then
  exit 0
fi

exec 9>"$cache_lock"
if ! flock -n 9; then
  for _ in $(seq 1 80); do
    if [ "${1:-}" != "--refresh" ] && emit_cached_list; then
      exit 0
    fi
    sleep 0.05
  done

  flock 9
  if [ "${1:-}" != "--refresh" ] && emit_cached_list; then
    exit 0
  fi
fi

make_thumb() {
  local input="$1"
  local output="$2"

  command -v ffmpeg >/dev/null 2>&1 || return 0
  [ -s "$output" ] && return 0

  ffmpeg -hide_banner -loglevel error -y \
    -ss 2 -i "$input" \
    -frames:v 1 \
    -vf "scale=640:-2:force_original_aspect_ratio=decrease" \
    "$output" >/dev/null 2>&1 || true
}

safe_name() {
  local base="$1"
  printf '%s' "$base" | tr -c 'A-Za-z0-9._-' '_'
}

cache_key() {
  local input="$1"
  local size mtime

  size="$(stat -c '%s' "$input" 2>/dev/null || printf '0')"
  mtime="$(stat -c '%Y' "$input" 2>/dev/null || printf '0')"
  printf '%s|%s|%s' "$input" "$size" "$mtime" | sha256sum | awk '{print $1}'
}

cache_preview_ram() {
  local input="$1"
  local key output tmp

  [ -f "$input" ] || {
    printf '%s' "$input"
    return 0
  }

  key="$(cache_key "$input")"
  output="$cache_ram/${key}.jpg"
  [ -s "$output" ] && {
    printf '%s' "$output"
    return 0
  }

  tmp="$cache_ram/${key}.$$-tmp.jpg"
  if command -v magick >/dev/null 2>&1; then
    magick "${input}[0]" -auto-orient -resize '1200x720>' -strip -quality 84 "$tmp" >/dev/null 2>&1 || true
  elif command -v convert >/dev/null 2>&1; then
    convert "${input}[0]" -auto-orient -resize '1200x720>' -strip -quality 84 "$tmp" >/dev/null 2>&1 || true
  elif command -v ffmpeg >/dev/null 2>&1; then
    ffmpeg -hide_banner -loglevel error -y -i "$input" -frames:v 1 -vf "scale=1200:-2:force_original_aspect_ratio=decrease" "$tmp" >/dev/null 2>&1 || true
  fi

  if [ -s "$tmp" ]; then
    mv -f "$tmp" "$output"
    printf '%s' "$output"
  else
    rm -f "$tmp"
    printf '%s' "$input"
  fi
}

project_preview() {
  local root="$1"
  python3 - "$root" <<'PY' 2>/dev/null || true
import json
import os
import sys

root = sys.argv[1]
try:
    with open(os.path.join(root, "project.json"), "r", encoding="utf-8", errors="ignore") as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)

for key in ("preview", "thumbnail", "cover", "image"):
    val = data.get(key)
    if isinstance(val, str) and val.strip():
        path = val if os.path.isabs(val) else os.path.join(root, val)
        if os.path.exists(path):
            print(path)
            break
PY
}

project_title() {
  local root="$1"
  python3 - "$root" <<'PY' 2>/dev/null || true
import json
import os
import sys

root = sys.argv[1]
try:
    with open(os.path.join(root, "project.json"), "r", encoding="utf-8", errors="ignore") as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)

title = data.get("title") or data.get("name")
if isinstance(title, str) and title.strip():
    print(title.strip().replace("|", " "))
PY
}

emit_static_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0

  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    local preview
    [ -n "${seen_static[$file]:-}" ] && continue
    seen_static[$file]=1
    preview="$(cache_preview_ram "$file")"
    printf 'STATIC|%s|%s|%s\n' "$file" "$preview" "$(basename "${file%.*}")"
  done
}

emit_live_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0

  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    local base safe thumb
    base="$(basename "$file")"
    safe="$(safe_name "${base%.*}")"
    thumb="$cache_live/${safe}.jpg"
    make_thumb "$file" "$thumb"
    if [ -s "$thumb" ]; then
      thumb="$(cache_preview_ram "$thumb")"
    else
      thumb=""
    fi
    printf 'LIVE|%s|%s|%s\n' "$file" "$thumb" "${base%.*}"
  done
}

emit_engine_root() {
  local root="$1"
  [ -d "$root" ] || return 0

  for dir in "$root"/*/; do
    [ -d "$dir" ] || continue

    local id preview gif video still thumb title
    id="$(basename "$dir")"
    [ -n "${seen_engine[$id]:-}" ] && continue
    seen_engine[$id]=1

    preview=""
    title="$(project_title "$dir")"
    [ -n "$title" ] || title="Workshop $id"

    gif="$(find "$dir" -maxdepth 5 -type f \
      \( -iname 'preview*.gif' -o -iname 'thumbnail*.gif' -o -iname 'thumb*.gif' -o -iname 'cover*.gif' -o -iname '*.gif' \) \
      2>/dev/null | sort | head -1 || true)"
    if [ -n "$gif" ]; then
      thumb="$cache_engine/${id}.jpg"
      make_thumb "$gif" "$thumb"
      if [ -s "$thumb" ]; then
        preview="$thumb"
      else
        preview="$gif"
      fi
    fi

    if [ -z "$preview" ]; then
      for ext in jpg png jpeg webp; do
        still="$cache_engine/${id}.${ext}"
        if [ -s "$still" ]; then
          preview="$still"
          break
        fi
      done
    fi

    if [ -z "$preview" ]; then
      preview="$(project_preview "$dir")"
    fi

    if [ -z "$preview" ]; then
      still="$(find "$dir" -maxdepth 5 -type f \
        \( -iname 'preview.*' -o -iname 'thumbnail.*' -o -iname 'thumb.*' -o -iname 'cover.*' -o -iname 'icon.*' \) \
        \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.gif' \) \
        2>/dev/null | sort | head -1 || true)"
      preview="$still"
    fi

    if [ -z "$preview" ]; then
      video="$(find "$dir" -maxdepth 5 -type f \
        \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) \
        2>/dev/null | sort | head -1 || true)"
      if [ -n "$video" ]; then
        thumb="$cache_engine/${id}.jpg"
        make_thumb "$video" "$thumb"
        [ -s "$thumb" ] && preview="$thumb"
      fi
    fi

    [ -n "$preview" ] || continue
    preview="$(cache_preview_ram "$preview")"
    printf 'ENGINE|%s|%s|%s\n' "$id" "$preview" "$title"
  done
}

tmp_list="$cache_ram/wallpapers.$$-tmp.list"
trap 'rm -f "$tmp_list"' EXIT

{
  printf 'BEGIN\n'
  emit_static_dir "$HOME/Pictures/Wallpapers/static"
  emit_static_dir "$HOME/Pictures/Wallpapers/WallpaperSelector"
  emit_live_dir "$HOME/Pictures/Wallpapers/live"
  emit_engine_root "$HOME/.steam/steam/steamapps/workshop/content/431960"
  emit_engine_root "$HOME/.local/share/Steam/steamapps/workshop/content/431960"
  printf 'END\n'
} | tee "$tmp_list"

[ -s "$tmp_list" ] && mv -f "$tmp_list" "$cache_list"
