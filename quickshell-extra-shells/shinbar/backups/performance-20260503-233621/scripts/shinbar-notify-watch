#!/usr/bin/env python3
import html
import json
import re
import subprocess
import sys
import time

def clean(text: str) -> str:
    text = text.replace("\\n", " ")
    text = text.replace('\\"', '"')
    text = html.unescape(text)
    text = re.sub(r"<[^>]+>", "", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text

def cut(text: str, limit: int) -> str:
    text = clean(text)
    if len(text) <= limit:
        return text
    return text[:limit - 1].rstrip() + "…"

try:
    proc = subprocess.Popen(
        ["dbus-monitor", "--session", "interface='org.freedesktop.Notifications',member='Notify'"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )
except FileNotFoundError:
    print(json.dumps({
        "app": "Shinbar",
        "summary": "dbus-monitor não encontrado",
        "body": "Instale dbus/libnotify para capturar notificações.",
        "time": int(time.time() * 1000),
    }, ensure_ascii=False), flush=True)
    sys.exit(1)

active = False
strings = []

for line in proc.stdout:
    if "member=Notify" in line:
        active = True
        strings = []
        continue

    if not active:
        continue

    m = re.search(r'^\s*string\s+"(.*)"\s*$', line)
    if not m:
        continue

    strings.append(m.group(1))

    # Notify(app_name, replaces_id, app_icon, summary, body, actions, hints, timeout)
    if len(strings) >= 4:
        app = cut(strings[0] or "App", 28)
        summary = cut(strings[2] or "Notificação", 64)
        body = cut(strings[3] or "", 150)

        print(json.dumps({
            "app": app,
            "summary": summary,
            "body": body,
            "time": int(time.time() * 1000),
        }, ensure_ascii=False), flush=True)

        active = False
        strings = []
