#!/usr/bin/env bash
set -euo pipefail

kind="${1:-}"
path="${2:-}"
preview="${3:-}"
transition="${4:-fade}"

[ -n "$kind" ] || exit 2
[ -n "$path" ] || exit 2

cache_dir="$HOME/.cache/testebar"
mkdir -p "$cache_dir"

theme_path="$path"
[ -n "$preview" ] && [ -f "$preview" ] && theme_path="$preview"
printf '%s|%s|%s\n' "$kind" "$path" "$theme_path" > "$cache_dir/current_wallpaper"

apply_pywal() {
  local img="$1"
  [ -f "$img" ] || return 0
  command -v wal >/dev/null 2>&1 || return 0
  wal -i "$img" -n -q >/dev/null 2>&1 || true
}

monitors() {
  hyprctl monitors -j 2>/dev/null | python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
    out = [m.get("name", "") for m in data if m.get("name")]
    print(" ".join(out))
except Exception:
    print("")
' 2>/dev/null || true
}

case "$kind" in
  static)
    if ! pgrep -x awww-daemon >/dev/null 2>&1; then
      nohup awww-daemon -q >/dev/null 2>&1 &
      sleep 0.15
    fi
    awww img "$path" --transition-type "$transition" --transition-duration 1 --transition-fps 60
    apply_pywal "$path"
    (sleep 0.85; pkill -x mpvpaper >/dev/null 2>&1 || true; pkill -x linux-wallpaperengine >/dev/null 2>&1 || true) >/dev/null 2>&1 &
    ;;
  live)
    apply_pywal "$theme_path"
    mons="$(monitors)"
    [ -n "$mons" ] || mons="eDP-1"
    pkill -x mpvpaper >/dev/null 2>&1 || true
    sleep 0.10
    : > /tmp/testebar-mpvpaper.log
    for mon in $mons; do
      nohup mpvpaper -o 'no-audio loop-file=inf panscan=1.0 video-unscaled=no hwdec=auto-safe scale=bilinear cscale=bilinear dscale=bilinear interpolation=no deband=no' "$mon" "$path" >>/tmp/testebar-mpvpaper.log 2>&1 &
    done
    (sleep 0.85; pkill -x linux-wallpaperengine >/dev/null 2>&1 || true; awww kill >/dev/null 2>&1 || true) >/dev/null 2>&1 &
    ;;
  engine)
    apply_pywal "$theme_path"
    pkill -x linux-wallpaperengine >/dev/null 2>&1 || true
    sleep 0.18
    nohup linux-wallpaperengine --screen-root eDP-1 --bg "$path" >/tmp/testebar-wallpaperengine.log 2>&1 &
    (sleep 0.85; pkill -x mpvpaper >/dev/null 2>&1 || true; awww kill >/dev/null 2>&1 || true) >/dev/null 2>&1 &
    ;;
  *)
    exit 2
    ;;
esac
