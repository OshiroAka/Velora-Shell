  lyrics)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        read_lyrics_settings
        ;;
      set)
        enabled="$(normalize_on_off "${3:-off}")"
        pos_x="$(clamp_decimal "${4:-18}" "18" "0" "100")"
        pos_y="$(clamp_decimal "${5:-44}" "44" "0" "100")"
        color_mode="$(normalize_lyrics_color_mode "${6:-pywal}")"
        manual_color="$(normalize_hex_color "${7:-#f5f7ff}")"
        font_size="$(clamp_decimal "${8:-86}" "86" "24" "180")"
        opacity="$(clamp_decimal "${9:-0.86}" "0.86" "0.15" "1.00")"
        spacing="$(clamp_decimal "${10:-8}" "8" "0" "48")"
        shadow="$(normalize_on_off "${11:-on}")"
        uppercase="$(normalize_on_off "${12:-on}")"
        layout="$(normalize_lyrics_layout "${13:-vertical}")"
        animation="$(normalize_lyrics_animation "${14:-instant}")"
        active_word="$(normalize_on_off "${15:-on}")"
        reveal_mode="$(normalize_lyrics_reveal "${16:-progressive}")"
        pos2_x="$(clamp_decimal "${17:-74}" "74" "0" "100")"
        pos2_y="$(clamp_decimal "${18:-18}" "18" "0" "100")"
        sync_offset="$(clamp_decimal "${19:-460}" "460" "-3000" "3000")"
        float_enabled="$(normalize_on_off "${20:-on}")"
        float_intensity="$(clamp_decimal "${21:-5}" "5" "0" "24")"
        if [[ "${22:-}" == "glow" ]]; then
          glow_enabled="$(normalize_on_off "${23:-on}")"
          glow_intensity="$(clamp_decimal "${24:-0.45}" "0.45" "0" "1.00")"
        else
          glow_enabled="$(normalize_on_off "${22:-on}")"
          glow_intensity="$(clamp_decimal "${23:-0.45}" "0.45" "0" "1.00")"
        fi
        mkdir -p "$state_dir"
        printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|glow|%s|%s\n' "$enabled" "$pos_x" "$pos_y" "$color_mode" "$manual_color" "$font_size" "$opacity" "$spacing" "$shadow" "$uppercase" "$layout" "$animation" "$active_word" "$reveal_mode" "$pos2_x" "$pos2_y" "$sync_offset" "$float_enabled" "$float_intensity" "$glow_enabled" "$glow_intensity" > "$lyrics_file"
        ;;
      reset)
        rm -f "$lyrics_file"
        ;;
      *)
        printf 'usage: %s lyrics get|set|reset [enabled x y pywal|palette|manual color font_size opacity spacing shadow uppercase layout animation active_word reveal_mode x2 y2 sync_ms(-3000..3000) float_enabled float_px glow_enabled glow_strength]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  lyrics-cinematic)
    subcommand="${2:-get}"
    case "$subcommand" in
