#!/usr/bin/env bash
set -euo pipefail

cache_engine="$HOME/.cache/testebar/engine-previews"
cache_live="$HOME/.cache/testebar/live-previews"
declare -A seen_engine=()
mkdir -p "$cache_engine" "$cache_live"

make_thumb() {
  local input="$1"
  local output="$2"
  command -v ffmpeg >/dev/null 2>&1 || return 0
  [ -s "$output" ] && return 0
  ffmpeg -hide_banner -loglevel error -y \
    -ss 2 -i "$input" \
    -frames:v 1 \
    -vf "scale=480:-2:force_original_aspect_ratio=decrease" \
    "$output" >/dev/null 2>&1 || true
}

emit_static_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.avif' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    printf 'STATIC|%s|%s|%s\n' "$file" "$file" "$(basename "$file")"
  done
}

emit_live_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    local base name thumb
    base="$(basename "$file")"
    name="${base%.*}"
    thumb="$cache_live/${name}.jpg"
    make_thumb "$file" "$thumb"
    [ -s "$thumb" ] || thumb=""
    printf 'LIVE|%s|%s|%s\n' "$file" "$thumb" "$base"
  done
}

printf 'BEGIN\n'

# Prefer the organized folders, but include the user's Pictures/Wallpaper tree too.
emit_static_dir "$HOME/Pictures/Wallpapers/static"
emit_static_dir "$HOME/Pictures/Wallpapers/WallpaperSelector"
emit_static_dir "$HOME/Pictures/Wallpaper"
emit_static_dir "$HOME/Pictures"

emit_live_dir "$HOME/Pictures/Wallpapers/live"
emit_live_dir "$HOME/Pictures/Wallpapers/mpv"
emit_live_dir "$HOME/Pictures/Wallpaper/live"

for root in \
  "$HOME/.steam/steam/steamapps/workshop/content/431960" \
  "$HOME/.local/share/Steam/steamapps/workshop/content/431960"
do
  [ -d "$root" ] || continue

  for dir in "$root"/*/; do
    [ -d "$dir" ] || continue
    id="$(basename "$dir")"
    [ -n "${seen_engine[$id]:-}" ] && continue
    seen_engine[$id]=1
    preview=""
    title="Workshop ${id}"

    if [ -f "$dir/project.json" ]; then
      parsed="$(python3 - "$dir" <<'PY' 2>/dev/null || true
import json, os, sys
root = sys.argv[1]
try:
    data = json.load(open(os.path.join(root, "project.json"), "r", encoding="utf-8", errors="ignore"))
except Exception:
    sys.exit(0)
title = data.get("title") or data.get("name") or ""
preview = ""
for key in ("preview", "thumbnail", "cover", "image"):
    val = data.get(key)
    if isinstance(val, str) and val.strip():
        path = val if os.path.isabs(val) else os.path.join(root, val)
        if os.path.exists(path):
            preview = path
            break
print(title.replace("|", " ").strip())
print(preview)
PY
)"
      title="$(printf '%s\n' "$parsed" | sed -n '1p')"
      preview="$(printf '%s\n' "$parsed" | sed -n '2p')"
      [ -n "$title" ] || title="Workshop ${id}"
    fi

    if [ -z "$preview" ]; then
      preview="$(find "$dir" -maxdepth 5 -type f \
        \( -iname 'preview*.gif' -o -iname 'thumbnail*.gif' -o -iname 'thumb*.gif' -o -iname 'cover*.gif' -o -iname '*.gif' \) \
        2>/dev/null | sort | head -1 || true)"
    fi

    if [ -n "$preview" ]; then
      thumb="$cache_engine/${id}.jpg"
      make_thumb "$preview" "$thumb"
      [ -s "$thumb" ] && preview="$thumb"
    fi

    if [ -z "$preview" ]; then
      video="$(find "$dir" -maxdepth 5 -type f \
        \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) \
        2>/dev/null | sort | head -1 || true)"
      if [ -n "$video" ]; then
        preview="$cache_engine/${id}.jpg"
        make_thumb "$video" "$preview"
      fi
    fi

    if [ -z "$preview" ] || [ ! -s "$preview" ]; then
      preview="$(find "$dir" -maxdepth 5 -type f \
        \( -iname 'preview.*' -o -iname 'thumbnail.*' -o -iname 'thumb.*' -o -iname 'cover.*' -o -iname 'icon.*' \) \
        \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.avif' \) \
        2>/dev/null | sort | head -1 || true)"
    fi

    printf 'ENGINE|%s|%s|%s\n' "$id" "$preview" "$title"
  done
done

printf 'END\n'
