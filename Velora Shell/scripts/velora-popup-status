#!/usr/bin/env bash
set -u

force=0
mode="${1:-all}"

if [[ "$mode" == "--force" ]]; then
    force=1
    mode="${2:-all}"
elif [[ "${2:-}" == "--force" ]]; then
    force=1
fi

cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/velora-shell/status"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
audio_control_script="$script_dir/velora-audio-control"

safe_mode_name() {
    printf '%s' "${1:-all}" | tr -cd '[:alnum:]_.-'
}

mode_ttl() {
    case "$1" in
        audio|brightness) printf '5' ;;
        wifi) printf '8' ;;
        notifications|notification-count) printf '4' ;;
        bluetooth) printf '8' ;;
        battery) printf '30' ;;
        files) printf '45' ;;
        quick|bar) printf '4' ;;
        *) printf '5' ;;
    esac
}

cache_file_for() {
    printf '%s/%s.cache' "$cache_root" "$(safe_mode_name "$1")"
}

read_cache() {
    local key="$1" file ttl now mtime
    (( force == 0 )) || return 1
    file="$(cache_file_for "$key")"
    [[ -s "$file" ]] || return 1
    ttl="$(mode_ttl "$key")"
    now="$(date +%s)"
    mtime="$(stat -c %Y "$file" 2>/dev/null || printf '0')"
    if (( now - mtime <= ttl )); then
        cat "$file"
        return 0
    fi
    return 1
}

write_cache() {
    local key="$1" data="$2" file tmp
    mkdir -p "$cache_root" 2>/dev/null || return 0
    file="$(cache_file_for "$key")"
    tmp="${file}.$$"
    printf '%s\n' "$data" > "$tmp" 2>/dev/null && mv -f "$tmp" "$file" 2>/dev/null || rm -f "$tmp"
}

with_cache() {
    local key="$1"
    shift
    if read_cache "$key"; then
        return 0
    fi

    local data
    data="$("$@")"
    write_cache "$key" "$data"
    printf '%s\n' "$data"
}

clean_field() {
    printf '%s' "${1:-}" | tr '\n\r|' '   ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

age_label() {
    local ts="${1:-0}"
    local now diff
    now="$(date +%s)"
    ts="${ts%.*}"
    [[ "$ts" =~ ^[0-9]+$ ]] || ts="$now"
    diff=$((now - ts))
    if (( diff < 60 )); then
        printf 'now'
    elif (( diff < 3600 )); then
        printf '%dm' $((diff / 60))
    elif (( diff < 86400 )); then
        printf '%dh' $((diff / 3600))
    else
        printf '%dd' $((diff / 86400))
    fi
}

icon_for_path() {
    local path="${1,,}"
    case "$path" in
        *download*|*downloads*) printf 'download' ;;
        *desktop*|*área*|*area*) printf 'display' ;;
        *picture*|*imagem*|*image*|*.png|*.jpg|*.jpeg|*.webp|*.gif) printf 'image' ;;
        *music*|*música*|*.mp3|*.flac|*.ogg|*.wav) printf 'volume' ;;
        *video*|*.mp4|*.mkv|*.webm|*.mov) printf 'play' ;;
        *document*|*documento*|*.pdf|*.txt|*.md|*.doc*|*.odt|*.ppt*|*.xls*) printf 'memo' ;;
        *) printf 'folder' ;;
    esac
}

wp_volume_line() {
    local target="$1"
    wpctl get-volume "$target" 2>/dev/null || true
}

wp_volume_value() {
    awk '{ for (i = 1; i <= NF; i++) if ($i ~ /^[0-9]+(\.[0-9]+)?$/) { print $i; exit } }' <<<"${1:-}"
}

wp_muted_value() {
    if [[ "${1:-}" == *MUTED* ]]; then
        printf '1'
    else
        printf '0'
    fi
}

wp_node_name() {
    local target="$1"
    wpctl inspect "$target" 2>/dev/null \
        | awk -F' = ' '
            /device.profile.description|node.nick|node.description|device.description|media.name/ {
                gsub(/^"/, "", $2)
                gsub(/"$/, "", $2)
                print $2
                exit
            }'
}

friendly_audio_name() {
    local raw
    raw="$(clean_field "${1:-}")"
    raw="${raw#Raptor Lake-P/U/H cAVS }"
    raw="${raw#cAVS }"

    case "${raw,,}" in
        ""|"default output") printf 'Saída padrão' ;;
        "default input") printf 'Entrada padrão' ;;
        "speaker") printf 'Alto-falante' ;;
        "digital microphone") printf 'Microfone digital' ;;
        "stereo microphone") printf 'Microfone estéreo' ;;
        *"hdmi"*"/"*"displayport"*|*"hdmi"*"displayport"*) printf '%s' "$raw" ;;
        *) printf '%s' "$raw" ;;
    esac
}

audio_status_field() {
    local status="$1" key="$2"
    printf '%s\n' "$status" | tr '|' '\n' | awk -F= -v wanted="$key" '$1 == wanted { print $2; exit }'
}

emit_audio() {
    local sink_line source_line sink_vol source_vol sink_name source_name audio_status preset engine
    sink_line="$(wp_volume_line '@DEFAULT_AUDIO_SINK@')"
    source_line="$(wp_volume_line '@DEFAULT_AUDIO_SOURCE@')"
    sink_vol="$(wp_volume_value "$sink_line")"
    source_vol="$(wp_volume_value "$source_line")"
    sink_name="$(wp_node_name '@DEFAULT_AUDIO_SINK@')"
    source_name="$(wp_node_name '@DEFAULT_AUDIO_SOURCE@')"
    if [[ -x "$audio_control_script" ]]; then
        audio_status="$("$audio_control_script" status 2>/dev/null || true)"
    fi
    preset="$(audio_status_field "$audio_status" preset)"
    engine="$(audio_status_field "$audio_status" ee)"

    printf 'AUDIO_SINK|%s|%s|%s\n' "${sink_vol:-0.60}" "$(wp_muted_value "$sink_line")" "$(friendly_audio_name "${sink_name:-Default output}")"
    printf 'AUDIO_SOURCE|%s|%s|%s\n' "${source_vol:-0.00}" "$(wp_muted_value "$source_line")" "$(friendly_audio_name "${source_name:-Default input}")"
    printf 'AUDIO_PRESET|%s|%s\n' "$(clean_field "${preset:-Custom}")" "$(clean_field "${engine:-missing}")"
}

emit_brightness() {
    local line
    line="$(brightnessctl -m 2>/dev/null | awk -F, '{gsub(/%/,"",$4); printf "BRIGHTNESS|%s|%s\n", $4/100, $1; exit}')"
    if [[ -n "$line" ]]; then
        printf '%s\n' "$line"
    else
        printf 'BRIGHTNESS|0.86|\n'
    fi
}

emit_wifi() {
    if ! command -v nmcli >/dev/null 2>&1; then
        printf 'RADIO|disabled\n'
        return
    fi

    printf 'RADIO|'
    nmcli -t -f WIFI radio 2>/dev/null || printf 'disabled\n'
    nmcli -t -f ACTIVE,SSID,SIGNAL,SECURITY dev wifi list 2>/dev/null \
        | awk -F: 'NF>=3 && $2!="" {print $1 "|" $2 "|" $3 "|" $4}'
}

emit_notifications() {
    if ! command -v makoctl >/dev/null 2>&1; then
        printf '[]\n'
        return
    fi

    makoctl list -j 2>/dev/null \
        | python3 -c 'import sys,json; raw=sys.stdin.read().strip() or "[]"; print(json.dumps(json.loads(raw), ensure_ascii=False))' 2>/dev/null \
        || printf '[]\n'
}

emit_notification_count() {
    if ! command -v makoctl >/dev/null 2>&1; then
        printf '0\n'
        return
    fi

    makoctl list -j 2>/dev/null \
        | python3 -c 'import sys,json; raw=sys.stdin.read().strip() or "[]"; print(len(json.loads(raw)))' 2>/dev/null \
        || printf '0\n'
}

emit_bluetooth() {
    if ! command -v bluetoothctl >/dev/null 2>&1; then
        printf 'POWER|unavailable\n'
        return
    fi

    local power
    power="$(bluetoothctl show 2>/dev/null | awk -F': ' '/Powered/ {print $2; exit}')"
    [[ -n "$power" ]] || power=unknown
    printf 'POWER|%s\n' "$power"
    bluetoothctl devices Connected 2>/dev/null | sed -n 's/^Device \([^ ]*\) \(.*\)$/CONNECTED|\1|\2/p'
    bluetoothctl devices Paired 2>/dev/null | sed -n 's/^Device \([^ ]*\) \(.*\)$/PAIRED|\1|\2/p'
    bluetoothctl devices 2>/dev/null | sed -n 's/^Device \([^ ]*\) \(.*\)$/KNOWN|\1|\2/p'
}

emit_quick() {
    emit_audio
    emit_brightness
    emit_wifi
    emit_notifications
}

emit_bar() {
    emit_audio
    emit_notification_count
}

emit_files() {
    local home_dir used size pct mount pct_num
    home_dir="${HOME:-/home/shira}"
    read -r used size pct mount < <(df -hP "$home_dir" 2>/dev/null | awk 'NR == 2 { print $3, $2, $5, $6 }')
    pct_num="${pct%\%}"
    [[ "$pct_num" =~ ^[0-9]+$ ]] || pct_num=0
    printf 'DISK|%s / %s|%s|%s\n' "$(clean_field "${used:-0}")" "$(clean_field "${size:-0}")" "$(awk -v p="$pct_num" 'BEGIN { printf "%.3f", p / 100 }')" "$(clean_field "${mount:-$home_dir}")"

    local dirs=(
        "$home_dir/Downloads" "$home_dir/Documentos" "$home_dir/Documents"
        "$home_dir/Desktop" "$home_dir/Área de trabalho"
        "$home_dir/Pictures" "$home_dir/Imagens" "$home_dir/Music" "$home_dir/Música"
        "$home_dir/Videos" "$home_dir/Vídeos"
    )

    {
        for d in "${dirs[@]}"; do
            [[ -d "$d" ]] || continue
            find "$d" -mindepth 0 -maxdepth 2 -type d -printf '%T@|%p\n' 2>/dev/null
        done
    } | grep -v '/\.' | sort -t '|' -k1,1nr | awk -F'|' '!seen[$2]++ { print; if (++count >= 8) exit }' \
        | while IFS='|' read -r ts path; do
            [[ -n "${path:-}" ]] || continue
            printf 'FOLDER|%s|%s|%s|%s\n' "$(icon_for_path "$path")" "$(clean_field "$(basename "$path")")" "$(age_label "$ts")" "$(clean_field "$path")"
        done

    {
        for d in "${dirs[@]}"; do
            [[ -d "$d" ]] || continue
            find "$d" -mindepth 1 -maxdepth 3 -type f -printf '%T@|%p\n' 2>/dev/null
        done
    } | grep -v '/\.' | sort -t '|' -k1,1nr | awk -F'|' '!seen[$2]++ { print; if (++count >= 8) exit }' \
        | while IFS='|' read -r ts path; do
            [[ -n "${path:-}" ]] || continue
            printf 'FILE|%s|%s|%s|%s\n' "$(icon_for_path "$path")" "$(clean_field "$(basename "$path")")" "$(age_label "$ts")" "$(clean_field "$path")"
        done
}

emit_battery() {
    local bat pct state time_text profile ac online
    bat="$(upower -e 2>/dev/null | grep -m1 -E 'BAT|battery' || true)"
    if [[ -n "$bat" ]]; then
        pct="$(upower -i "$bat" 2>/dev/null | awk -F: '/percentage/ { gsub(/[%[:space:]]/, "", $2); print $2 / 100; exit }')"
        state="$(upower -i "$bat" 2>/dev/null | awk -F: '/state/ { gsub(/^[[:space:]]+/, "", $2); print $2; exit }')"
        time_text="$(upower -i "$bat" 2>/dev/null | awk -F: '/time to empty|time to full/ { gsub(/^[[:space:]]+/, "", $2); print $2; exit }')"
    fi
    if [[ -z "${pct:-}" || "$pct" == "0" ]]; then
        for cap in /sys/class/power_supply/BAT*/capacity; do
            [[ -r "$cap" ]] || continue
            pct="$(awk '{ print $1 / 100 }' "$cap" 2>/dev/null)"
            break
        done
    fi
    if [[ -z "${state:-}" ]]; then
        for status in /sys/class/power_supply/BAT*/status; do
            [[ -r "$status" ]] || continue
            state="$(cat "$status" 2>/dev/null)"
            break
        done
    fi

    ac="$(upower -e 2>/dev/null | grep -m1 -E 'line_power|AC' || true)"
    if [[ -n "$ac" ]]; then
        online="$(upower -i "$ac" 2>/dev/null | awk -F: '/online/ { gsub(/^[[:space:]]+/, "", $2); print $2; exit }')"
    fi
    if [[ -z "${online:-}" ]]; then
        for ac_online in /sys/class/power_supply/A*/online; do
            [[ -r "$ac_online" ]] || continue
            online="$(cat "$ac_online" 2>/dev/null)"
            break
        done
    fi

    profile="$(powerprofilesctl get 2>/dev/null || true)"
    printf 'BATTERY|%s|%s|%s\n' "${pct:-0}" "$(clean_field "${state:-unknown}")" "$(clean_field "${time_text:-}")"
    printf 'POWER|%s|%s\n' "$(clean_field "${profile:-unknown}")" "$(clean_field "${online:-unknown}")"
}

case "$mode" in
    audio) with_cache audio emit_audio ;;
    brightness) with_cache brightness emit_brightness ;;
    wifi) with_cache wifi emit_wifi ;;
    notifications) with_cache notifications emit_notifications ;;
    notification-count) with_cache notification-count emit_notification_count ;;
    bluetooth) with_cache bluetooth emit_bluetooth ;;
    files) with_cache files emit_files ;;
    battery) with_cache battery emit_battery ;;
    quick) with_cache quick emit_quick ;;
    bar) with_cache bar emit_bar ;;
    all)
        emit_audio
        emit_brightness
        emit_wifi
        emit_notifications
        emit_files
        emit_battery
        ;;
    *)
        printf 'unknown mode: %s\n' "$mode" >&2
        exit 2
        ;;
esac
