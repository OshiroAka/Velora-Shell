#!/usr/bin/env python3
import json
import sys
from pathlib import Path

base = Path.home() / ".config" / "quickshell" / "testebar"
path = base / "savedata.json"

defaults = {
    "themeMode": "dark",
    "wallpaperCategory": "static",
    "wallpaperTransitionType": "fade",
    "wallpaperTransitionDuration": 1.0,
    "interfaceOpacity": 0.46,
    "autoThemeSwitch": False,
    "pywalAccentEnabled": True,
    "manualAccentChoice": "#9cd1ff",
    "currentWallpaperKey": "",
}


def load():
    if not path.exists():
        return dict(defaults)

    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        data = {}

    out = dict(defaults)
    if isinstance(data, dict):
        out.update(data)
    return out


def coerce(key, raw):
    if key in ("autoThemeSwitch", "pywalAccentEnabled"):
        return str(raw).lower() in ("1", "true", "yes", "on")
    if key in ("wallpaperTransitionDuration", "interfaceOpacity"):
        try:
            return float(raw)
        except ValueError:
            return defaults[key]
    return str(raw)


def save(data):
    base.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(path)


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "get"
    data = load()

    if cmd == "get":
        for key in defaults:
            print(f"{key}={data.get(key, defaults[key])}")
        return 0

    if cmd == "set" and len(sys.argv) >= 4:
        key = sys.argv[2]
        if key not in defaults:
            return 2
        data[key] = coerce(key, sys.argv[3])
        save(data)
        return 0

    if cmd == "init":
        save(data)
        return 0

    return 1


if __name__ == "__main__":
    raise SystemExit(main())
