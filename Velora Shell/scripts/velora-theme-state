        exit 2
        ;;
    esac
    ;;
  bar-appearance)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        read_bar_appearance
        ;;
      set)
        icon_size="$(clamp_decimal "${3:-48}" "48" "32" "56")"
        icon_opacity="$(clamp_decimal "${4:-0.80}" "0.80" "0.30" "1.00")"
        icon_spacing="$(clamp_decimal "${5:-16}" "16" "8" "24")"
        auto_hide="$(normalize_on_off "${6:-off}")"
        corner_radius="$(clamp_decimal "${7:-16}" "16" "0" "30")"
        mkdir -p "$state_dir"
        printf '%s|%s|%s|%s|%s\n' "$icon_size" "$icon_opacity" "$icon_spacing" "$auto_hide" "$corner_radius" > "$bar_appearance_file"
        ;;
      reset)
        rm -f "$bar_appearance_file"
        ;;
      *)
        printf 'usage: %s bar-appearance get|set|reset [icon_size icon_opacity icon_spacing auto_hide corner_radius]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  profile-image)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$profile_image_file" ]]; then
          cat "$profile_image_file"
        else
          printf '\n'
        fi
        ;;
      set)
        profile_image="${3:-}"
        profile_image="${profile_image//$'\n'/}"
        mkdir -p "$state_dir"
        printf '%s\n' "$profile_image" > "$profile_image_file"
        ;;
      reset)
        rm -f "$profile_image_file"
