  topbar)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$topbar_file" ]]; then
          cat "$topbar_file"
        else
          printf 'off\n'
        fi
        ;;
      set)
        enabled="${3:-off}"
        case "$enabled" in
          1|true|yes|on|enabled) enabled="on" ;;
          *) enabled="off" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s\n' "$enabled" > "$topbar_file"
        ;;
      reset)
        rm -f "$topbar_file"
        ;;
