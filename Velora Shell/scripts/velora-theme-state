  *)
    printf 'usage: %s get|dump|set [theme] | opacity get|set|reset [sidebar popup card] | bar-opacity get|set|reset [opacity] | glow get|set|reset [general sidebar_border popup_border icon text] | border get|set|reset [adapt|manual hue] | layout get|set|reset [left|right] [0|1] | language get|set|reset [ja|en|pt-BR] | font get|set|reset [noto|adwaita|cantarell|dejavu|liberation|fantasque] | visualizer get|set|reset [strength] | visualizer-mode get|set|reset [wave|pixels] | visualizer-pixel-size get|set|reset [3-12] | visualizer-gradient get|set|reset [on|off] | popup-attach get|set|reset [on|off] | popup-bubbles get|set|reset [solid|matched] | bar-labels get|set|reset [on|off] | bar-blur get|set|reset [on|off] | frame-blur get|set|reset [on|off] | bar-appearance get|set|reset [icon_size icon_opacity icon_spacing auto_hide corner_radius] | profile-image get|set|reset [path] | topbar get|set|reset [on|off] | topbar-frame-line get|set|reset [on|off] | lyrics get|set|reset [settings] | lyrics-cinematic get|set|reset [on|off] | lyrics-material get|set|reset [settings] | wallpaper-transition get|set|reset [transition duration delay]\n' "$0" >&2
