#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/velora-shell"
state_file="${state_dir}/theme"
opacity_file="${state_dir}/opacity"
bar_opacity_file="${state_dir}/bar-opacity"
glow_file="${state_dir}/glow"
border_file="${state_dir}/border"
layout_file="${state_dir}/layout"
language_file="${state_dir}/language"
visualizer_file="${state_dir}/visualizer"
command="${1:-get}"

case "$command" in
  get)
    if [[ -s "$state_file" ]]; then
      cat "$state_file"
    else
      printf 'default\n'
    fi
    ;;
  dump)
    theme="default"
    opacity="auto"
    bar_opacity="auto"
    glow="auto"
    border="auto"
    layout="left|1"
    language="ja"
    visualizer="0.46"

    [[ -s "$state_file" ]] && theme="$(cat "$state_file")"
    [[ -s "$opacity_file" ]] && opacity="$(cat "$opacity_file")"
    [[ -s "$bar_opacity_file" ]] && bar_opacity="$(cat "$bar_opacity_file")"
    [[ -s "$glow_file" ]] && glow="$(cat "$glow_file")"
    [[ -s "$border_file" ]] && border="$(cat "$border_file")"
    [[ -s "$layout_file" ]] && layout="$(cat "$layout_file")"
    [[ -s "$language_file" ]] && language="$(cat "$language_file")"
    [[ -s "$visualizer_file" ]] && visualizer="$(cat "$visualizer_file")"

    printf 'theme|%s\n' "$theme"
    printf 'opacity|%s\n' "$opacity"
    printf 'barOpacity|%s\n' "$bar_opacity"
    printf 'glow|%s\n' "$glow"
    printf 'border|%s\n' "$border"
    printf 'layout|%s\n' "$layout"
    printf 'language|%s\n' "$language"
    printf 'visualizer|%s\n' "$visualizer"
    ;;
  set)
    theme="${2:-default}"
    case "$theme" in
      default|dark|pink|lavender|pywal16) ;;
      *) theme="default" ;;
    esac
    mkdir -p "$state_dir"
    printf '%s\n' "$theme" > "$state_file"
    ;;
  opacity)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$opacity_file" ]]; then
          cat "$opacity_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        sidebar="${3:-auto}"
        popup="${4:-auto}"
        card="${5:-auto}"
        mkdir -p "$state_dir"
        printf '%s|%s|%s\n' "$sidebar" "$popup" "$card" > "$opacity_file"
        ;;
      reset)
        rm -f "$opacity_file" "$bar_opacity_file"
        ;;
      *)
        printf 'usage: %s opacity get|set|reset [sidebar popup card]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  bar-opacity)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$bar_opacity_file" ]]; then
          cat "$bar_opacity_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        opacity="${3:-auto}"
        mkdir -p "$state_dir"
        printf '%s\n' "$opacity" > "$bar_opacity_file"
        ;;
      reset)
        rm -f "$bar_opacity_file"
        ;;
      *)
        printf 'usage: %s bar-opacity get|set|reset [opacity]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  glow)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$glow_file" ]]; then
          cat "$glow_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        general="${3:-auto}"
        sidebar_border="${4:-auto}"
        popup_border="${5:-auto}"
        icon="${6:-$general}"
        text="${7:-auto}"
        mkdir -p "$state_dir"
        printf '%s|%s|%s|%s|%s\n' "$general" "$sidebar_border" "$popup_border" "$icon" "$text" > "$glow_file"
        ;;
      reset)
        rm -f "$glow_file"
        ;;
      *)
        printf 'usage: %s glow get|set|reset [general sidebar_border popup_border icon text]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  border)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$border_file" ]]; then
          cat "$border_file"
        else
          printf 'auto\n'
        fi
        ;;
      set)
        mode="${3:-adapt}"
        hue="${4:-0.55}"
        case "$mode" in
          adapt|manual) ;;
          *) mode="adapt" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s|%s\n' "$mode" "$hue" > "$border_file"
        ;;
      reset)
        rm -f "$border_file"
        ;;
      *)
        printf 'usage: %s border get|set|reset [adapt|manual hue]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  layout)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$layout_file" ]]; then
          cat "$layout_file"
        else
          printf 'left|1\n'
        fi
        ;;
      set)
        position="${3:-left}"
        frame="${4:-1}"
        case "$position" in
          left|right) ;;
          *) position="left" ;;
        esac
        case "$frame" in
          1|true|yes|on) frame="1" ;;
          *) frame="0" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s|%s\n' "$position" "$frame" > "$layout_file"
        ;;
      reset)
        rm -f "$layout_file"
        ;;
      *)
        printf 'usage: %s layout get|set|reset [left|right] [0|1]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  language)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$language_file" ]]; then
          cat "$language_file"
        else
          printf 'ja\n'
        fi
        ;;
      set)
        language="${3:-ja}"
        case "$language" in
          ja|jp|japanese) language="ja" ;;
          en|english) language="en" ;;
          pt|pt-BR|pt_BR|br|portuguese|portugues) language="pt-BR" ;;
          *) language="ja" ;;
        esac
        mkdir -p "$state_dir"
        printf '%s\n' "$language" > "$language_file"
        ;;
      reset)
        rm -f "$language_file"
        ;;
      *)
        printf 'usage: %s language get|set|reset [ja|en|pt-BR]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  visualizer)
    subcommand="${2:-get}"
    case "$subcommand" in
      get)
        if [[ -s "$visualizer_file" ]]; then
          cat "$visualizer_file"
        else
          printf '0.46\n'
        fi
        ;;
      set)
        strength="${3:-0.46}"
        mkdir -p "$state_dir"
        printf '%s\n' "$strength" > "$visualizer_file"
        ;;
      reset)
        rm -f "$visualizer_file"
        ;;
      *)
        printf 'usage: %s visualizer get|set|reset [strength]\n' "$0" >&2
        exit 2
        ;;
    esac
    ;;
  *)
    printf 'usage: %s get|dump|set [theme] | opacity get|set|reset [sidebar popup card] | bar-opacity get|set|reset [opacity] | glow get|set|reset [general sidebar_border popup_border icon text] | border get|set|reset [adapt|manual hue] | layout get|set|reset [left|right] [0|1] | language get|set|reset [ja|en|pt-BR] | visualizer get|set|reset [strength]\n' "$0" >&2
    exit 2
    ;;
esac
