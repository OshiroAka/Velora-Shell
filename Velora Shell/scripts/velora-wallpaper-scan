#!/usr/bin/env bash
set -euo pipefail

cache_root="$HOME/.cache/velora-shell"
cache_live="$cache_root/live-previews"
cache_engine="$cache_root/engine-previews"
declare -A seen_static=()
declare -A seen_engine=()

mkdir -p "$cache_live" "$cache_engine"

make_thumb() {
  local input="$1"
  local output="$2"

  command -v ffmpeg >/dev/null 2>&1 || return 0
  [ -s "$output" ] && return 0

  ffmpeg -hide_banner -loglevel error -y \
    -ss 2 -i "$input" \
    -frames:v 1 \
    -vf "scale=640:-2:force_original_aspect_ratio=decrease" \
    "$output" >/dev/null 2>&1 || true
}

safe_name() {
  local base="$1"
  printf '%s' "$base" | tr -c 'A-Za-z0-9._-' '_'
}

project_preview() {
  local root="$1"
  python3 - "$root" <<'PY' 2>/dev/null || true
import json
import os
import sys

root = sys.argv[1]
try:
    with open(os.path.join(root, "project.json"), "r", encoding="utf-8", errors="ignore") as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)

for key in ("preview", "thumbnail", "cover", "image"):
    val = data.get(key)
    if isinstance(val, str) and val.strip():
        path = val if os.path.isabs(val) else os.path.join(root, val)
        if os.path.exists(path):
            print(path)
            break
PY
}

project_title() {
  local root="$1"
  python3 - "$root" <<'PY' 2>/dev/null || true
import json
import os
import sys

root = sys.argv[1]
try:
    with open(os.path.join(root, "project.json"), "r", encoding="utf-8", errors="ignore") as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)

title = data.get("title") or data.get("name")
if isinstance(title, str) and title.strip():
    print(title.strip().replace("|", " "))
PY
}

emit_static_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0

  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    [ -n "${seen_static[$file]:-}" ] && continue
    seen_static[$file]=1
    printf 'STATIC|%s|%s|%s\n' "$file" "$file" "$(basename "${file%.*}")"
  done
}

emit_live_dir() {
  local dir="$1"
  [ -d "$dir" ] || return 0

  find "$dir" -maxdepth 1 -type f \
    \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' -o -iname '*.gif' \) \
    2>/dev/null | sort | while IFS= read -r file; do
    local base safe thumb
    base="$(basename "$file")"
    safe="$(safe_name "${base%.*}")"
    thumb="$cache_live/${safe}.jpg"
    make_thumb "$file" "$thumb"
    [ -s "$thumb" ] || thumb=""
    printf 'LIVE|%s|%s|%s\n' "$file" "$thumb" "${base%.*}"
  done
}

emit_engine_root() {
  local root="$1"
  [ -d "$root" ] || return 0

  for dir in "$root"/*/; do
    [ -d "$dir" ] || continue

    local id preview gif video still thumb title
    id="$(basename "$dir")"
    [ -n "${seen_engine[$id]:-}" ] && continue
    seen_engine[$id]=1

    preview=""
    title="$(project_title "$dir")"
    [ -n "$title" ] || title="Workshop $id"

    gif="$(find "$dir" -maxdepth 5 -type f \
      \( -iname 'preview*.gif' -o -iname 'thumbnail*.gif' -o -iname 'thumb*.gif' -o -iname 'cover*.gif' -o -iname '*.gif' \) \
      2>/dev/null | sort | head -1 || true)"
    if [ -n "$gif" ]; then
      thumb="$cache_engine/${id}.jpg"
      make_thumb "$gif" "$thumb"
      if [ -s "$thumb" ]; then
        preview="$thumb"
      else
        preview="$gif"
      fi
    fi

    if [ -z "$preview" ]; then
      for ext in jpg png jpeg webp; do
        still="$cache_engine/${id}.${ext}"
        if [ -s "$still" ]; then
          preview="$still"
          break
        fi
      done
    fi

    if [ -z "$preview" ]; then
      preview="$(project_preview "$dir")"
    fi

    if [ -z "$preview" ]; then
      still="$(find "$dir" -maxdepth 5 -type f \
        \( -iname 'preview.*' -o -iname 'thumbnail.*' -o -iname 'thumb.*' -o -iname 'cover.*' -o -iname 'icon.*' \) \
        \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.gif' \) \
        2>/dev/null | sort | head -1 || true)"
      preview="$still"
    fi

    if [ -z "$preview" ]; then
      video="$(find "$dir" -maxdepth 5 -type f \
        \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) \
        2>/dev/null | sort | head -1 || true)"
      if [ -n "$video" ]; then
        thumb="$cache_engine/${id}.jpg"
        make_thumb "$video" "$thumb"
        [ -s "$thumb" ] && preview="$thumb"
      fi
    fi

    [ -n "$preview" ] || continue
    printf 'ENGINE|%s|%s|%s\n' "$id" "$preview" "$title"
  done
}

printf 'BEGIN\n'
emit_static_dir "$HOME/Pictures/Wallpapers/static"
emit_static_dir "$HOME/Pictures/Wallpapers/WallpaperSelector"
emit_live_dir "$HOME/Pictures/Wallpapers/live"
emit_engine_root "$HOME/.steam/steam/steamapps/workshop/content/431960"
emit_engine_root "$HOME/.local/share/Steam/steamapps/workshop/content/431960"
printf 'END\n'
